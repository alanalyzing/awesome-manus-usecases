{
  "manifest_version": 3,
  "name": "Manus Use Case Quick Launcher",
  "version": "2.1.0",
  "description": "Browse and launch Manus use cases from a convenient side panel. Search by category, open session replays, and discover what people build with Manus.",
  "permissions": ["storage", "sidePanel", "tabGroups"],
  "host_permissions": ["https://awesome.manus.space/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Open Manus Use Case Quick Launcher"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
